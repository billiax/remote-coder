# Server
PORT=3333
# API_KEY=your-secret-key
# DEFAULT_ENGINE=claude                  # claude | opencode

# Workspaces
# BASE_DIR=./workspaces
# ALLOWED_WORKSPACES=project-a,project-b

# MCP (e.g. Context7)
# MCP_CONFIG=./mcp-config.json

# Claude engine — set ONE of these
# ANTHROPIC_API_KEY=sk-ant-...           # SDK mode
# CLAUDE_CODE_OAUTH_TOKEN=...            # CLI mode (uses claude CLI)
# ANTHROPIC_BASE_URL=https://your-proxy  # Optional: route via proxy

# Database (optional — sessions/activity tracked in PostgreSQL)
# DATABASE_URL=postgresql://user:pass@host/remote_coder_dev

# Auto-compact threshold (input tokens, default 200000)
# AUTO_COMPACT_TOKENS=200000

# OpenCode engine
# OPENCODE_PROVIDER_API_KEY=...          # API key for your OpenAI-compatible proxy
